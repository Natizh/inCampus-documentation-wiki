{
  "name": "wiki-web-viewer",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "first-run": "node ./scripts/first-run.mjs",
    "dev": "npm-run-all -p dev:server dev:client",
    "dev:client": "vite",
    "dev:server": "sh -c 'PORT=${WIKIOS_DEV_SERVER_PORT:-5212} tsx watch src/server/server.ts'",
    "build": "npm run build:client && npm run build:server && npm run build:config",
    "build:client": "vite build",
    "build:server": "sh -c 'rm -rf dist-server tsconfig.server.tsbuildinfo && tsc -p tsconfig.server.json'",
    "build:config": "sh -c 'if [ -f wiki-os.config.ts ]; then tsc --pretty false --target ES2022 --module commonjs --moduleResolution node --outDir dist-server wiki-os.config.ts; fi'",
    "serve": "node dist-server/server/server.js",
    "start": "node ./scripts/start-user-mode.mjs",
    "deploy": "bash ./scripts/deploy.sh",
    "smoke-test": "bash ./scripts/smoke-test.sh",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/static": "^9.1.0",
    "better-sqlite3": "^12.8.0",
    "fastify": "^5.8.4",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-types": "^0.24.8",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.542.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sigma": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9",
    "globals": "^17.4.0",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  }
}
