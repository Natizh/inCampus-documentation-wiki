# InCampus local default
# By default this viewer uses ../inCampusLLMwiki/wiki relative to wiki-web-viewer.
# Leave WIKI_ROOT empty unless you intentionally want to point at a different wiki.
WIKI_ROOT=

# Optional forced per-process override for one run
WIKIOS_FORCE_WIKI_ROOT=

# Optional runtime settings
PORT=5211
WIKIOS_INDEX_DB=
WIKIOS_ADMIN_TOKEN=
WIKIOS_DISABLE_WATCH=0
WIKIOS_OPEN_BROWSER=1

# Optional helper settings for scripts and local smoke tests
WIKIOS_BASE_URL=http://localhost:5211
WIKIOS_RESTART_COMMAND=
